<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>DepartmentEmployeeAPI</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- ADO.NET driver — no ORM. SqlConnection / SqlCommand / SqlDataReader are
         used directly in the Repositories layer against the stored procedures
         from DepartmentEmployee_DB_Design.sql -->
    <PackageReference Include="Microsoft.Data.SqlClient" Version="5.2.2" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.6.2" />
  </ItemGroup>

</Project>
